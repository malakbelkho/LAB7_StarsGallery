<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_screen">

    <LinearLayout
        android:id="@+id/splashCard"
        android:layout_width="260dp"
        android:layout_height="300dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_splash_card"
        android:elevation="12dp">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/star"
            android:contentDescription="Logo Stars" />

        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stars Gallery"
            android:textColor="#5A2E86"
            android:textStyle="bold"
            android:textSize="25sp"
            android:layout_marginTop="22dp" />

        <TextView
            android:id="@+id/splashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explore • Rate • Share"
            android:textColor="#7A6A96"
            android:textSize="13sp"
            android:layout_marginTop="6dp" />

    </LinearLayout>

</FrameLayout>